# Database
DATABASE_URL="postgresql://user:password@localhost:5432/resume_builder"
DIRECT_URL="postgresql://user:password@localhost:5432/resume_builder"

# NextAuth / Auth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-random-32-byte-secret"
AUTH_SECRET="replace-with-a-random-32-byte-secret"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Google Gemini API
GEMINI_API_KEY="your-google-gemini-api-key"

# Email via Resend
RESEND_API_KEY="your-resend-api-key"
RESEND_FROM="ResumeIQ <noreply@yourdomain.com>"

# Application
NODE_ENV="development"

# Backend API URL
# BACKEND_URL is server-side only (used by Next.js API route proxies)
BACKEND_URL="http://localhost:5000"
# NEXT_PUBLIC_BACKEND_URL is exposed to the browser (use only when necessary)
NEXT_PUBLIC_BACKEND_URL="http://localhost:5000"
